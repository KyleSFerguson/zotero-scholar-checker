{
  "manifest_version": 3,
  "name": "Google Scholar-Zotero Library Checker",
  "version": "1.0",
  "description": "Instantly see the reading and PDF status of Zotero library papers while browsing Goggle Scholar.",
  "permissions": ["storage"],
  "host_permissions": [
    "*://scholar.google.com/*",
    "https://api.zotero.org/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://scholar.google.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icon16.jpg",
    "48": "icon48.jpg",
    "128": "icon128.jpg"
  }
}
